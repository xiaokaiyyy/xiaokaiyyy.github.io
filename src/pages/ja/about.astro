---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n/ui.ts';
import profileZh from '../../data/profile.json';
import profileEn from '../../data/profile.en.json';
import profileJa from '../../data/profile.ja.json';

const locale = Astro.currentLocale || 'zh';
const profile = locale === 'en' ? profileEn : locale === 'ja' ? profileJa : profileZh;

const aboutContent = {
  zh: {
    p1: `你好！我是 ${profile.name}，一名热爱技术的开发者。我对前端开发和全栈技术有着浓厚的兴趣，喜欢探索新的工具和框架，致力于构建简洁、高效且用户友好的应用。`,
    p2: '在空闲时间，我喜欢阅读技术博客、参与开源项目，以及尝试各种新奇的编程语言。我相信持续学习和分享是技术成长的最佳方式。',
    p3: '如果你对我的项目感兴趣，或者想聊聊技术，欢迎通过联系方式页面与我取得联系。',
  },
  en: {
    p1: `Hello! I'm ${profile.name}, a developer passionate about technology. I have a strong interest in frontend development and full-stack technologies, enjoy exploring new tools and frameworks, and am dedicated to building clean, efficient, and user-friendly applications.`,
    p2: 'In my spare time, I enjoy reading tech blogs, contributing to open source projects, and experimenting with various interesting programming languages. I believe continuous learning and sharing are the best ways to grow technically.',
    p3: 'If you are interested in my projects or want to chat about technology, feel free to reach out through the contact page.',
  },
  ja: {
    p1: `こんにちは！${profile.name} です。技術が大好きな開発者です。フロントエンド開発とフルスタック技術に強い関心を持ち、新しいツールやフレームワークを探求することが好きで、シンプルで効率的、かつユーザーフレンドリーなアプリケーションの構築に尽力しています。`,
    p2: '暇な時間には、技術ブログを読んだり、オープンソースプロジェクトに貢献したり、様々な興味深いプログラミング言語を試したりしています。継続的な学習と知識の共有が、技術的成長の最良の方法だと信じています。',
    p3: '私のプロジェクトに興味がある方、または技術について話したい方は、お問い合わせページから気軽に連絡してください。',
  },
};

const content = aboutContent[locale];
---

<Layout title={`${t(locale, 'about.title')} - ${profile.name}`} description={`${t(locale, 'about.title')} - ${profile.name}`}>
  <Navbar />

  <main class="flex-1 pt-16 font-mono">
    <div class="max-w-[900px] mx-auto px-4 sm:px-6 py-16 space-y-16">
      <!-- About content -->
      <section class="animate-fade-in-up">
        <div class="flex items-center gap-2 text-sm text-[#888] mb-6">
          <span class="text-[#27c93f]">➜</span>
          <span>~</span>
          <span>cat about.md</span>
        </div>
        <h1 class="text-2xl font-bold text-[#e0e0e0] text-glow mb-6"># {t(locale, 'about.title')}</h1>
        <div class="space-y-4 text-[#e0e0e0] leading-relaxed">
          <p>{content.p1}</p>
          <p>{content.p2}</p>
          <p>{content.p3}</p>
        </div>
      </section>

      <!-- Skills -->
      <section class="animate-fade-in-up stagger-2">
        <div class="flex items-center gap-2 text-sm text-[#888] mb-6">
          <span class="text-[#27c93f]">➜</span>
          <span>~</span>
          <span>ls skills/</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="border border-[#333] bg-[#111] p-5 hover:border-[#555] transition-colors duration-200">
            <h3 class="text-sm font-semibold text-[#888] mb-3 uppercase tracking-wide">## {t(locale, 'about.frontend')}</h3>
            <div class="flex flex-wrap gap-2 text-sm">
              {['JavaScript', 'TypeScript', 'React', 'Vue', 'Astro'].map(s => (
                <span class="text-[#e0e0e0]">[{s}]</span>
              ))}
            </div>
          </div>
          <div class="border border-[#333] bg-[#111] p-5 hover:border-[#555] transition-colors duration-200">
            <h3 class="text-sm font-semibold text-[#888] mb-3 uppercase tracking-wide">## {t(locale, 'about.backend')}</h3>
            <div class="flex flex-wrap gap-2 text-sm">
              {['Python', 'SAS', 'Git', 'Linux', 'AI Agent', 'PHP', 'SQL'].map(s => (
                <span class="text-[#e0e0e0]">[{s}]</span>
              ))}
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</Layout>

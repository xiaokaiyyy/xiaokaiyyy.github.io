---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { t } from '../i18n/ui.ts';
import profileZh from '../data/profile.json';
import profileEn from '../data/profile.en.json';
import profileJa from '../data/profile.ja.json';
import focusStackZh from '../data/focus-stack.json';
import focusStackEn from '../data/focus-stack.en.json';
import focusStackJa from '../data/focus-stack.ja.json';
import projectsZh from '../data/projects.json';
import projectsEn from '../data/projects.en.json';
import projectsJa from '../data/projects.ja.json';

const locale = Astro.currentLocale || 'zh';
const profile = locale === 'en' ? profileEn : locale === 'ja' ? profileJa : profileZh;
const focusStack = locale === 'en' ? focusStackEn : locale === 'ja' ? focusStackJa : focusStackZh;
const projects = locale === 'en' ? projectsEn : locale === 'ja' ? projectsJa : projectsZh;
---

<Layout title={`${t(locale, 'projects.title')} - ${profile.name}`} description={`${profile.name} - ${t(locale, 'projects.subtitle')}`}>
  <Navbar />

  <main class="flex-1 pt-16 font-mono">
    <div class="max-w-[900px] mx-auto px-4 sm:px-6 py-16 space-y-16">
      <!-- Focus Stack -->
      <section class="animate-fade-in-up">
        <div class="flex items-center gap-2 text-sm text-[#888] mb-2">
          <span class="text-[#27c93f]">➜</span>
          <span>~</span>
          <span>{t(locale, 'projects.title')}</span>
        </div>
        <p class="text-[#888] mb-8 text-sm">{t(locale, 'projects.subtitle')}</p>

        <div class="flex items-center gap-2 text-sm text-[#888] mb-6">
          <span class="text-[#27c93f]">➜</span>
          <span>~</span>
          <span>{t(locale, 'projects.focusStack')}</span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {focusStack.map((tech, index) => (
            <div
              class="border border-[#333] bg-[#111] p-5 hover:border-[#555] transition-colors duration-200 animate-fade-in-up"
              style={`animation-delay: ${0.1 * (index + 1)}s`}
            >
              <div class="flex items-center justify-between mb-3">
                <h3 class="font-semibold text-[#e0e0e0]">[{tech.name}]</h3>
                <span class="text-xs text-[#555] px-2 py-0.5 border border-[#333]">
                  {tech.category}
                </span>
              </div>
              <p class="text-sm text-[#888] mb-4 leading-relaxed">{tech.description}</p>
              <div class="w-full bg-[#0c0c0c] h-1.5 overflow-hidden">
                <div
                  class="h-full transition-all duration-1000 ease-out"
                  style={`width: ${tech.level}%; background-color: #ff9f1c;`}
                />
              </div>
              <div class="text-right mt-1">
                <span class="text-xs text-[#555]">{tech.level}%</span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Project Thinking -->
      <section class="animate-fade-in-up stagger-2">
        <div class="flex items-center gap-2 text-sm text-[#888] mb-6">
          <span class="text-[#27c93f]">➜</span>
          <span>~</span>
          <span>{t(locale, 'projects.thinking')}</span>
        </div>
        <div class="space-y-4">
          {projects.map((project, index) => (
            <div
              class="border border-[#333] bg-[#111] p-5 hover:border-[#555] transition-colors duration-200 animate-fade-in-up"
              style={`animation-delay: ${0.15 * (index + 1)}s`}
            >
              <div class="flex items-center gap-3 mb-2 flex-wrap">
                <span class="text-xs font-medium text-[#ff9f1c] border border-[#ff9f1c]/30 px-2 py-0.5">
                  {project.category}
                </span>
                <span class="text-xs text-[#555]">{project.date}</span>
              </div>
              <h3 class="font-semibold text-[#e0e0e0] mb-2"># {project.title}</h3>
              <p class="text-sm text-[#888] leading-relaxed">{project.content}</p>
            </div>
          ))}
        </div>
      </section>
    </div>
  </main>

  <Footer />
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import SocialIcons from '../../components/SocialIcons.astro';
import SkillTags from '../../components/SkillTags.astro';
import Timeline from '../../components/Timeline.astro';
import Footer from '../../components/Footer.astro';
import profileZh from '../../data/profile.json';
import profileEn from '../../data/profile.en.json';
import profileJa from '../../data/profile.ja.json';

const locale = Astro.currentLocale || 'zh';
const profile = locale === 'en' ? profileEn : locale === 'ja' ? profileJa : profileZh;
---

<Layout title={`${profile.name}`} description={profile.bio}>
  <Navbar />

  <main class="flex-1 pt-16">
    <!-- Hero -->
    <section class="min-h-[calc(100vh-4rem)] flex flex-col items-center justify-center px-4 text-center animate-fade-in-up">
      <img
        src={profile.avatar}
        alt={profile.name}
        class="w-[120px] h-[120px] rounded-full object-cover shadow-lg mb-6 animate-breathe-in avatar-glow"
        loading="eager"
      />
      <h1 class="text-[32px] font-bold text-[var(--text-primary)] tracking-tight mb-3 font-serif animate-fade-in-up stagger-1">
        {profile.name}
      </h1>
      <p class="text-lg text-[var(--text-secondary)] mb-8 max-w-md animate-fade-in-up stagger-2">
        {profile.bio}
      </p>
      <div class="animate-fade-in-up stagger-3">
        <SocialIcons size={24} animated />
      </div>
    </section>

    <!-- Skills -->
    <SkillTags />

    <!-- Timeline -->
    <Timeline />
  </main>

  <Footer />
</Layout>

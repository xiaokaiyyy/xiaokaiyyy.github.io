---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import SocialIcons from '../../components/SocialIcons.astro';
import SkillTags from '../../components/SkillTags.astro';
import Timeline from '../../components/Timeline.astro';
import Footer from '../../components/Footer.astro';
import profileZh from '../../data/profile.json';
import profileEn from '../../data/profile.en.json';
import profileJa from '../../data/profile.ja.json';

const locale = Astro.currentLocale || 'zh';
const profile = locale === 'en' ? profileEn : locale === 'ja' ? profileJa : profileZh;
---

<Layout title={`${profile.name}`} description={profile.bio}>
  <Navbar />

  <main class="flex-1 pt-16 font-mono">
    <!-- Hero Terminal -->
    <section class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-4 sm:px-6 py-12">
      <div class="w-full max-w-[700px] border border-[#333] bg-[#111] animate-fade-in-up">
        <!-- Terminal header -->
        <div class="flex items-center gap-2 px-4 py-2 border-b border-[#333] bg-[#0c0c0c]">
          <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[#27c93f]"></span>
          <span class="ml-2 text-xs text-[#555]">profile.md — {profile.name}</span>
        </div>

        <!-- Terminal body -->
        <div class="p-4 sm:p-6 space-y-4">
          <!-- Command -->
          <div class="flex items-center gap-2 text-sm text-[#888]">
            <span class="text-[#27c93f]">➜</span>
            <span>~</span>
            <span class="animate-typewriter">cat profile.md</span>
          </div>

          <!-- Output -->
          <div class="space-y-2 animate-fade-in-up stagger-2">
            <h1 class="text-3xl sm:text-5xl font-bold text-[#e0e0e0] text-glow leading-tight">
              # {profile.name}
            </h1>
            <p class="text-base sm:text-lg text-[#888] leading-relaxed">
              {profile.bio}
            </p>
          </div>

          <!-- Links command -->
          <div class="flex items-center gap-2 text-sm text-[#888] animate-fade-in-up stagger-3">
            <span class="text-[#27c93f]">➜</span>
            <span>~</span>
            <span>ls links/</span>
          </div>

          <div class="animate-fade-in-up stagger-4">
            <SocialIcons size={22} animated />
          </div>

          <!-- Blinking cursor -->
          <div class="flex items-center gap-2 text-sm text-[#888] animate-fade-in-up stagger-5">
            <span class="text-[#27c93f]">➜</span>
            <span>~</span>
            <span class="animate-blink text-[#ff9f1c]">█</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills -->
    <SkillTags />

    <!-- Timeline -->
    <Timeline />
  </main>

  <Footer />
</Layout>

---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { t } from '../i18n/ui.ts';
import LangSwitcher from './LangSwitcher.astro';

const locale = Astro.currentLocale || 'zh';
const currentPath = Astro.url.pathname;
const basePath = currentPath.replace(/^\/(en|ja)(?=\/|$)/, '') || '/';

const normalizePath = (href: string) => href.replace(/^\/(en|ja)(?=\/|$)/, '') || '/';

const navLinks = [
  { path: '', label: t(locale, 'nav.home') },
  { path: 'about', label: t(locale, 'nav.about') },
  { path: 'projects', label: t(locale, 'nav.projects') },
  { path: 'contact', label: t(locale, 'nav.contact') },
];

const displayPath = basePath === '/' ? '~' : `~${basePath.replace(/^\//, '')}`;
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 bg-[#0c0c0c] border-b border-[#333] font-mono transition-colors duration-200">
  <div class="max-w-[900px] mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
    <!-- Left: dots + user@host -->
    <div class="flex items-center gap-3">
      <div class="hidden sm:flex items-center gap-1.5">
        <span class="w-3 h-3 rounded-full bg-[#ff5f56]"></span>
        <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
        <span class="w-3 h-3 rounded-full bg-[#27c93f]"></span>
      </div>
      <a href={getRelativeLocaleUrl(locale, '')} class="text-sm text-[#e0e0e0] hover:text-[#ff9f1c] transition-colors">
        <span class="text-[#888]">guest@</span>xiaokaiyyy<span class="text-[#888]">:</span><span class="text-[#27c93f]">{displayPath}</span>
      </a>
    </div>

    <!-- Desktop nav -->
    <div class="hidden sm:flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={getRelativeLocaleUrl(locale, link.path)}
          class={`px-2 py-1 text-sm transition-colors ${
            basePath === normalizePath(getRelativeLocaleUrl(locale, link.path))
              ? 'text-[#ff9f1c] bg-[#1a1a1a]'
              : 'text-[#888] hover:text-[#ff9f1c] hover:bg-[#1a1a1a]'
          }`}
        >
          {link.label}
        </a>
      ))}
      <div class="w-px h-4 bg-[#333] mx-1"></div>
      <LangSwitcher />
    </div>

    <!-- Mobile: lang switcher + hamburger -->
    <div class="sm:hidden flex items-center gap-1">
      <LangSwitcher />
      <button
        id="menu-toggle"
        class="p-2 text-[#e0e0e0]"
        aria-label="Toggle menu"
      >
        <svg id="menu-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    class="sm:hidden fixed inset-0 top-14 bg-[#0c0c0c] border-t border-[#333] transform translate-x-full transition-transform duration-200"
  >
    <div class="flex flex-col items-start gap-1 p-4 font-mono">
      {navLinks.map(link => (
        <a
          href={getRelativeLocaleUrl(locale, link.path)}
          class={`block w-full px-3 py-2 text-sm transition-colors ${
            basePath === normalizePath(getRelativeLocaleUrl(locale, link.path))
              ? 'text-[#ff9f1c] bg-[#1a1a1a]'
              : 'text-[#e0e0e0] hover:text-[#ff9f1c] hover:bg-[#1a1a1a]'
          }`}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  let isOpen = false;

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('border-[#555]');
      navbar?.classList.remove('border-[#333]');
    } else {
      navbar?.classList.remove('border-[#555]');
      navbar?.classList.add('border-[#333]');
    }
  });

  menuToggle?.addEventListener('click', () => {
    isOpen = !isOpen;
    if (isOpen) {
      mobileMenu?.classList.remove('translate-x-full');
    } else {
      mobileMenu?.classList.add('translate-x-full');
    }
  });
</script>

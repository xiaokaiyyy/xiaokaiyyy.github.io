---
import { t } from '../i18n/ui.ts';
import timelineZh from '../data/timeline.zh.json';
import timelineEn from '../data/timeline.en.json';
import timelineJa from '../data/timeline.ja.json';

const locale = Astro.currentLocale || 'zh';
const timeline = locale === 'en' ? timelineEn : locale === 'ja' ? timelineJa : timelineZh;
---

<section class="max-w-[600px] mx-auto px-4 sm:px-6 py-16">
  <h2 class="text-2xl font-semibold text-center mb-12 text-[var(--text-primary)] animate-on-scroll">{t(locale, 'timeline.title')}</h2>
  <div class="relative">
    <!-- Vertical line -->
    <div class="timeline-line absolute left-[7px] top-2 bottom-2 w-[2px] bg-[var(--border)]"></div>

    <div class="space-y-8">
      {timeline.map((event, index) => (
        <div class="timeline-item relative pl-8 group" data-delay={index}>
          <!-- Dot -->
          <div class="timeline-dot absolute left-0 top-2 w-4 h-4 rounded-full border-2 border-[var(--border)] bg-[var(--bg-primary)]
            group-hover:border-[var(--accent)] group-hover:bg-[var(--accent)] transition-colors duration-150">
          </div>

          <div class="space-y-1">
            <span class="text-[13px] text-[var(--text-secondary)] font-medium">{event.date}</span>
            <h3 class="text-base font-semibold text-[var(--text-primary)]">{event.title}</h3>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">{event.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const timelineLine = document.querySelector('.timeline-line');
  const timelineItems = document.querySelectorAll('.timeline-item');

  const lineObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          lineObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  if (timelineLine) lineObserver.observe(timelineLine);

  const itemObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = parseInt(el.dataset.delay || '0', 10);
          setTimeout(() => {
            el.classList.add('is-visible');
            const dot = el.querySelector('.timeline-dot');
            if (dot) dot.classList.add('is-visible');
          }, delay * 120);
          itemObserver.unobserve(el);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  timelineItems.forEach((item) => itemObserver.observe(item));
</script>

---
import { t } from '../i18n/ui.ts';
import timelineZh from '../data/timeline.zh.json';
import timelineEn from '../data/timeline.en.json';
import timelineJa from '../data/timeline.ja.json';

const locale = Astro.currentLocale || 'zh';
const timeline = locale === 'en' ? timelineEn : locale === 'ja' ? timelineJa : timelineZh;
---

<section class="max-w-[900px] mx-auto px-4 sm:px-6 pt-8 pb-16 font-mono">
  <div class="flex items-center gap-2 text-sm text-[#888] mb-12 animate-on-scroll">
    <span class="text-[#27c93f]">➜</span>
    <span>~</span>
    <span>{t(locale, 'timeline.title')}</span>
  </div>
  <div class="relative">
    <!-- Vertical line -->
    <div class="timeline-line absolute left-[7px] top-2 bottom-2 w-px bg-[#333]"></div>

    <div class="space-y-6">
      {timeline.map((event, index) => (
        <div class="timeline-item relative pl-8 group" data-delay={index}>
          <!-- Dot -->
          <div class="timeline-dot absolute left-0 top-1.5 w-3.5 h-3.5 border border-[#333] bg-[#0c0c0c]
            group-hover:border-[#ff9f1c] group-hover:bg-[#ff9f1c] transition-colors duration-150">
          </div>

          <div class="space-y-1">
            <div class="flex items-baseline gap-3 flex-wrap">
              <span class="text-xs text-[#555] font-mono">[{event.date}]</span>
              <h3 class="text-sm font-semibold text-[#e0e0e0]">{event.title}</h3>
            </div>
            <p class="text-sm text-[#888] leading-relaxed">{event.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const timelineLine = document.querySelector('.timeline-line');
  const timelineItems = document.querySelectorAll('.timeline-item');

  const lineObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          lineObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  if (timelineLine) lineObserver.observe(timelineLine);

  const itemObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = parseInt(el.dataset.delay || '0', 10);
          setTimeout(() => {
            el.classList.add('is-visible');
            const dot = el.querySelector('.timeline-dot');
            if (dot) dot.classList.add('is-visible');
          }, delay * 120);
          itemObserver.unobserve(el);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  timelineItems.forEach((item) => itemObserver.observe(item));
</script>

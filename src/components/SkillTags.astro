---
import skills from '../data/skills.json';
---

<section class="max-w-[800px] mx-auto px-4 sm:px-6 py-16">
  <h2 class="text-2xl font-semibold text-center mb-8 text-[var(--text-primary)] animate-on-scroll">技术栈</h2>
  <div class="flex flex-wrap justify-center gap-3">
    {skills.map((skill, index) => (
      <span
        class="skill-tag px-4 py-1.5 text-sm font-medium border border-[var(--border)] rounded-full text-[var(--text-primary)]
        hover:bg-[var(--bg-card)] hover:border-[var(--accent)] cursor-default"
        data-animate
        data-delay={index}
      >
        {skill}
      </span>
    ))}
  </div>
</section>

<script>
  const skillTags = document.querySelectorAll('.skill-tag[data-animate]');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = parseInt(el.dataset.delay || '0', 10);
          setTimeout(() => {
            el.classList.add('animate-pop-in');
          }, delay * 60);
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  skillTags.forEach((tag) => observer.observe(tag));
</script>

---
import { getRelativeLocaleUrl } from 'astro:i18n';

const currentLocale = Astro.currentLocale || 'zh';
const currentPath = Astro.url.pathname;

// Remove locale prefix to get base path
const basePath = currentPath.replace(/^\/(en|ja)(?=\/|$)/, '') || '/';
const pathParam = basePath === '/' ? '' : basePath.replace(/^\//, '');

const languages = [
  { code: 'zh', label: 'zh' },
  { code: 'en', label: 'en' },
  { code: 'ja', label: 'ja' },
];
---

<div class="relative font-mono" id="lang-switcher">
  <button
    id="lang-toggle"
    class="px-2 py-1 text-xs text-[#888] hover:text-[#ff9f1c] hover:bg-[#1a1a1a] transition-colors duration-150"
    aria-label="切换语言"
    aria-expanded="false"
  >
    {currentLocale}
  </button>

  <div
    id="lang-menu"
    class="hidden absolute right-0 mt-1 bg-[#0c0c0c] border border-[#333] py-1 z-50 min-w-[60px]"
  >
    {languages.map(lang => (
      <a
        href={getRelativeLocaleUrl(lang.code, pathParam)}
        class={`block px-3 py-1 text-xs transition-colors duration-150 ${
          lang.code === currentLocale
            ? 'text-[#ff9f1c] bg-[#1a1a1a]'
            : 'text-[#e0e0e0] hover:text-[#ff9f1c] hover:bg-[#1a1a1a]'
        }`}
      >
        {lang.label}
      </a>
    ))}
  </div>
</div>

<script>
  const langSwitcher = document.getElementById('lang-switcher');
  const langToggle = document.getElementById('lang-toggle');
  const langMenu = document.getElementById('lang-menu');

  langToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isHidden = langMenu?.classList.contains('hidden');
    if (isHidden) {
      langMenu?.classList.remove('hidden');
      langToggle.setAttribute('aria-expanded', 'true');
    } else {
      langMenu?.classList.add('hidden');
      langToggle.setAttribute('aria-expanded', 'false');
    }
  });

  document.addEventListener('click', (e) => {
    if (!langSwitcher?.contains(e.target as Node)) {
      langMenu?.classList.add('hidden');
      langToggle?.setAttribute('aria-expanded', 'false');
    }
  });
</script>

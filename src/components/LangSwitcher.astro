---
import { getRelativeLocaleUrl } from 'astro:i18n';

const currentLocale = Astro.currentLocale || 'zh';
const currentPath = Astro.url.pathname;

// Remove locale prefix to get base path
const basePath = currentPath.replace(/^\/(en|ja)(?=\/|$)/, '') || '/';
const pathParam = basePath === '/' ? '' : basePath.replace(/^\//, '');

const languages = [
  { code: 'zh', label: '中文', flag: '🇨🇳' },
  { code: 'en', label: 'English', flag: '🇺🇸' },
  { code: 'ja', label: '日本语', flag: '🇯🇵' },
];
---

<div class="relative" id="lang-switcher">
  <button
    id="lang-toggle"
    class="p-2 text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors duration-150 flex items-center gap-1 text-sm"
    aria-label="切换语言"
    aria-expanded="false"
  >
    <span class="text-base">🌐</span>
    <span class="hidden sm:inline">{languages.find(l => l.code === currentLocale)?.flag}</span>
  </button>

  <div
    id="lang-menu"
    class="hidden absolute right-0 mt-2 w-36 bg-[var(--bg-card)] border border-[var(--border)] rounded-lg shadow-lg py-1 z-50"
  >
    {languages.map(lang => (
      <a
        href={getRelativeLocaleUrl(lang.code, pathParam)}
        class={`block px-4 py-2 text-sm transition-colors duration-150 ${
          lang.code === currentLocale
            ? 'text-[var(--accent)] font-medium bg-[var(--accent)]/5'
            : 'text-[var(--text-primary)] hover:text-[var(--accent)] hover:bg-[var(--bg-primary)]'
        }`}
      >
        <span class="mr-2">{lang.flag}</span>
        {lang.label}
      </a>
    ))}
  </div>
</div>

<script>
  const langSwitcher = document.getElementById('lang-switcher');
  const langToggle = document.getElementById('lang-toggle');
  const langMenu = document.getElementById('lang-menu');

  langToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isHidden = langMenu?.classList.contains('hidden');
    if (isHidden) {
      langMenu?.classList.remove('hidden');
      langToggle.setAttribute('aria-expanded', 'true');
    } else {
      langMenu?.classList.add('hidden');
      langToggle.setAttribute('aria-expanded', 'false');
    }
  });

  document.addEventListener('click', (e) => {
    if (!langSwitcher?.contains(e.target as Node)) {
      langMenu?.classList.add('hidden');
      langToggle?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
